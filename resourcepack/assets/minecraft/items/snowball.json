{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "cases": [
      {
        "when": "impact_grenade",
        "model": {
          "type": "minecraft:condition",
          "property": "minecraft:selected",
          "on_true": {
            "type": "minecraft:model",
            "model": "ochak:item/impact_grenade"
          },
		  "on_false": {
            "type": "minecraft:model",
            "model": "minecraft:item/snowball"
          }
        }
      },
      {
        "when": "smoke_grenade",
        "model": {
          "type": "minecraft:condition",
          "property": "minecraft:selected",
          "on_true": {
            "type": "minecraft:model",
            "model": "ochak:item/smoke_grenade"
          },
		  "on_false": {
            "type": "minecraft:model",
            "model": "minecraft:item/snowball"
          }
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/snowball"
    }
  }
}